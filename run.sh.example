#!/bin/bash
set -e

DATA_DIR="/var/lib/daily-logger"
mkdir -p "$DATA_DIR"

export NTFY_BASE="https://ntfybaseurl..."
export NTFY_USER="yourusername"
export NTFY_PASS="yourpassword"
export DB_PATH="$DATA_DIR/logger.db"
export CHECK_HOUR="13"  # 24 hour format
export CHECK_TIMEZONE="Asia/Kolkata"

cd "$(dirname "$0")"
exec ./daily-logger